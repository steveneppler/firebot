# --- Required ---
# Discord webhook URL (Server Settings -> Integrations -> Webhooks -> New Webhook)
DISCORD_WEBHOOK_URL=

# NASA FIRMS map key (free): https://firms.modaps.eosdis.nasa.gov/api/map_key/
# Required only if FIRMS is enabled (it is by default).
FIRMS_MAP_KEY=

# --- Area (a square around the center, extending SQUARE_HALF_MILES to each edge) ---
CENTER_LAT=39.0639
CENTER_LON=-108.5506
SQUARE_HALF_MILES=300
# Place name used in "X mi <direction> of <label>" on satellite hotspot alerts.
CENTER_LABEL=Grand Junction

# --- Scheduling (loop mode) ---
POLL_INTERVAL_MIN=30

# Zoom level for the map deep-links (NIFC -> AirNow Fire & Smoke, FIRMS -> NASA FIRMS map).
MAP_LINK_ZOOM=9

# --- Static minimap image inside each alert embed (optional) ---
# Renders a small satellite map with a pin on the fire, in addition to the clickable
# coordinate link. Provider: none | mapbox.
#   none   = no image (default; unchanged behavior)
#   mapbox = satellite + labels; needs a free public token (https://account.mapbox.com)
STATIC_MAP_PROVIDER=none
# Mapbox public access token (leave blank when provider=none).
STATIC_MAP_KEY=
STATIC_MAP_ZOOM=11
STATIC_MAP_WIDTH=600
STATIC_MAP_HEIGHT=360
# Optional basemap style override (blank = satellite-streets-v12).
# e.g. satellite-streets-v12 | outdoors-v12 | streets-v12
STATIC_MAP_STYLE=

# --- Sources ---
ENABLE_NIFC=true
ENABLE_FIRMS=true

# --- NIFC options ---
# Comma-separated IncidentTypeCategory values. WF=wildfire, RX=prescribed burn, CX=complex.
NIFC_INCIDENT_TYPES=WF

# --- Incident update alerts (re-post when a known fire changes) ---
ENABLE_INCIDENT_UPDATES=true
UPDATE_ON_GROWTH=true
UPDATE_ON_CONTAINMENT=true
UPDATE_ON_OUT=true
# Growth alert when acreage rises by >= this percent OR >= this many acres since the last alert.
UPDATE_ACRES_PCT=25
UPDATE_ACRES_ABS=100
# Percent-growth also requires this many acres of absolute growth (suppresses tiny-fire spam).
UPDATE_ACRES_PCT_FLOOR=10
# Containment alert when % contained moves by >= this many points since the last alert.
UPDATE_CONTAINMENT_DELTA=20

# --- FIRMS options ---
# VIIRS_SNPP_NRT, VIIRS_NOAA20_NRT, VIIRS_NOAA21_NRT, MODIS_NRT, ...
FIRMS_SOURCE=VIIRS_SNPP_NRT
FIRMS_DAY_RANGE=1
# VIIRS confidence: low | nominal | high (keep this level or above).
# A 300-mile box in summer can return >1000 hotspots, so "high" is recommended.
FIRMS_VIIRS_MIN_CONFIDENCE=high
# MODIS only (0-100 confidence).
FIRMS_MIN_CONFIDENCE_PCT=0
# Drop hotspots with fire radiative power below this (MW). Cuts ag/industrial noise.
FIRMS_FRP_MIN=20
# Group detections within this many miles into ONE fire alert (one big fire = one alert).
# 0 disables clustering (one alert per detection).
FIRMS_CLUSTER_MILES=3
# Suppress hotspots within this many miles of a known NIFC incident (same fire). 0 = off.
FIRMS_SUPPRESS_NEAR_INCIDENT_MILES=5

# --- State ---
STATE_PATH=/data/state.json
STATE_RETENTION_DAYS=7
